{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "branch",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track golangci-lint version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["GOLANGCI_VERSION\\s*:=\\s*(?<currentValue>[0-9.]+)\\n"],
      "depNameTemplate": "github.com/golangci/golangci-lint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Track buf version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["BUF_VERSION\\s*:=\\s*v(?<currentValue>[0-9.]+)\\n"],
      "depNameTemplate": "bufbuild/buf",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Track act version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["ACT_VERSION\\s*:=\\s*(?<currentValue>[0-9.]+)\\n"],
      "depNameTemplate": "nektos/act",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Track govulncheck version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["GOVULNCHECK_VERSION\\s*:=\\s*v(?<currentValue>[0-9.]+)\\n"],
      "depNameTemplate": "golang/vuln",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Track gitleaks version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["GITLEAKS_VERSION\\s*:=\\s*(?<currentValue>[0-9.]+)\\n"],
      "depNameTemplate": "gitleaks/gitleaks",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Bump Go version in go.mod to latest patch",
      "matchManagers": [
        "gomod"
      ],
      "matchDepNames": [
        "go"
      ],
      "rangeStrategy": "bump"
    }
  ]
}
